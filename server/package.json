{
  "name": "@kartchain/server",
  "version": "0.1.0",
  "description": "Colyseus authoritative server for Kartchain races",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "keys:gen": "node scripts/gen-keys.mjs",
    "build": "npm run sim:build && npm run build:ts",
    "build:ts": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "sim:build": "cd ../sim && cargo rustc --release --target wasm32-unknown-unknown --crate-type cdylib",
    "sim:test": "cd ../sim && cargo test --release"
  },
  "dependencies": {
    "@colyseus/core": "^0.16.0",
    "@colyseus/monitor": "^0.16.0",
    "@colyseus/playground": "^0.16.0",
    "@colyseus/schema": "^3.0.0",
    "@colyseus/tools": "^0.16.0",
    "@colyseus/ws-transport": "^0.16.0",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.95.4",
    "dotenv": "^16.4.5",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@colyseus/testing": "^0.16.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=20"
  }
}
