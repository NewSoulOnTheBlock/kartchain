{
  "name": "@kartchain/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "npm run sim:copy && next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "sim:build": "cd ../sim && cargo rustc --release --target wasm32-unknown-unknown --crate-type cdylib",
    "sim:copy": "node scripts/sim-copy.cjs"
  },
  "dependencies": {
    "@solana/wallet-adapter-base": "^0.9.23",
    "@solana/wallet-adapter-phantom": "^0.9.24",
    "@solana/wallet-adapter-react": "^0.15.35",
    "@solana/wallet-adapter-react-ui": "^0.9.35",
    "@solana/wallet-adapter-solflare": "^0.6.28",
    "@solana/web3.js": "^1.95.4",
    "colyseus.js": "^0.16.6",
    "next": "^15.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.3",
    "typescript": "^5.6.3"
  }
}
