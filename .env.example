# ─── Shared ────────────────────────────────────────────────
# devnet | mainnet-beta | localnet
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com

# SPL token mint used for P2E rewards. Create with:
#   spl-token create-token --decimals 9 --mint-authority $(solana-keygen pubkey p2e-mint.json)
# then paste the mint address here.
P2E_TOKEN_MINT=

# ─── Server (server/.env) ──────────────────────────────────
PORT=2567
PUBLIC_URL=http://localhost:2567

# Custodial wallet keypairs (Solana CLI JSON byte-array format).
# Generate with: solana-keygen new --no-bip39-passphrase -o <file>.json
TREASURY_KEYPAIR_PATH=./treasury.json
ESCROW_KEYPAIR_PATH=./escrow.json
P2E_MINT_AUTHORITY_KEYPAIR_PATH=./p2e-mint.json
# Optional — only needed if you mint Metaplex Core kart NFTs from the server.
KART_NFT_AUTHORITY_KEYPAIR_PATH=

# Admin token for /api/admin/mint-kart (rotate freely)
ADMIN_TOKEN=changeme-please

# Optional Redis for multi-instance scaling
REDIS_URL=

# ─── Web (web/.env.local) ──────────────────────────────────
NEXT_PUBLIC_COLYSEUS_URL=ws://localhost:2567
NEXT_PUBLIC_SERVER_URL=http://localhost:2567
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_P2E_TOKEN_MINT=
